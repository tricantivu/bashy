#!/usr/bin/env bash

printError() {
    printf "$1\n" >&2
}

trap '{ printError "\nScript was interrupted."; exit 1; }' SIGINT

type -P pamac &> /dev/null || { printError 'pamac is not installed!' >&2; exit 1; }

ping -c 3 manjaro.org &> /dev/null || {
    printError "Can not check for updates, please check your connection."

    exit 1
}

pamac checkupdates --aur &> /dev/null

if [[ $? -eq 100 ]]; then
    notify-send 'chk4up' "System updates are available, applying them!"

    pamac upgrade --aur --no-confirm &> /dev/null || {

        notify-send 'chk4up' "Updates could not be applied, pamac failed."

        exit 1
    }

    notify-send 'chk4up' "Updates applied successfully!"
else
    notify-send 'chk4up' "No system updates are available!"
fi

trap &> /dev/null
