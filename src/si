trap '{ printf "%b\n" "\nScript was interrupted."; exit 1; }' SIGINT

# Global variables
readonly RED="\e[31m" GREEN="\e[32m" YELLOW="\e[33m" BLUE="\e[34m" COLOR_END="\e[0m"                                                                # (Reference: https://dev.to/ifenna__/adding-colors-to-bash-scripts-48g4)

. /etc/os-release

# Functions
welcomeMessage() {
    printf "%b\n\n" "${RED}System information for:${COLOR_END} ${YELLOW}${USER}${COLOR_END}${GREEN}@${COLOR_END}${BLUE}${HOSTNAME}${COLOR_END}"     # Use some rainbow colors in the message.
}

debianCount() {
    echo -n "Packages: "; grep -vc 'Listing...' < <(apt list --installed 2>&-)                                                                      # Silence warnings/errors in apt.
}

fedoraCount() {
    echo -n "Packages: "; wc -l < <(dnf list --installed) || \
    echo -n "Packages: "; wc -l < <(yum list --installed)                                                                                           # Fallback to yum
}

archCount() {
    echo -n "Packages: "; wc -l < <(pacman -Qq)
}

packageCount() {

    # Detect distribution.
    case "${ID_LIKE:-$ID}" in
        (arch)
            archCount
        ;;
        (fedora)
            fedoraCount
        ;;
        (debian)
            debianCount
        ;;
        (*)
            echo "Packages: N/A"
        ;;
    esac
}

getDistribution() {
    local distributionName

    distributionName="${PRETTY_NAME:-$NAME}"

    printf "%s\n" "Distribution: ${distributionName}"
}

getShell() {
    printf "%s\n" "Shell: ${SHELL##*/}"
}

osInfo() {
    local operatingSystem kernelRelease

    # Parse OS name.
    case "${OSTYPE}" in
        (linux-gnu)
            operatingSystem='GNU/Linux'
        ;;
        (*)
            operatingSystem="${OSTYPE}"
        ;;
    esac

    kernelRelease="$(uname -r)"

    printf "%s\n" "OS: ${operatingSystem}" "Kernel: ${kernelRelease}" "Architecture: ${HOSTTYPE}"
}

welcomeMessage
getShell
osInfo
packageCount
getDistribution

trap &> /dev/null
