# Functions
usage() {
    local scriptName="${0##*/}"

cat << USAGE
Description: Show information of a process identifier.
Usage: ${scriptName} <OPTION> <PID>

Available options:

    -p PID
        Show the information for process identifier PID.

    -h
        Show script usage.
USAGE
}

printError() {
    printf -- "$1\n" >&2
}

processName() {
    local processName

    read -r processName < "/proc/${PID}/comm"

    printf 'Process: %s\n' "${processName}"
}

processStatus() {
    local fileLine

    while read -r fileLine; do
        [[ "${fileLine}" == State:* ]] && {
            # Parse the status.
            prefixRemoved="${fileLine#State:}"
            tabRemoved="${prefixRemoved##$'\t'}"
            letterRemoved="${tabRemoved#[RSDZTItWXxKP]' '}"
            parenthesisRemoved="${letterRemoved//[()]/}"

            printf 'Status: %s\n' "${parenthesisRemoved^}"

            break
        }

    done < <(cat "/proc/${PID}/status")
}

processFDs() {
    local fileDescriptors

    fileDescriptors="$(find "/proc/${PID}/fd" -type l -printf '%f, ' 2>&-)"

    [[ -z "${fileDescriptors}" ]] && {

        printError "Can not show PID ${PID}'s file descriptors, lacking permissions or none were opened."

        return 1
    }

    printf 'Open file descriptors: %s\n\n' "${fileDescriptors%, }"
}

processCommand() {
    local processCommand

    processCommand="$(tr '\0' ' ' 2>&- < "/proc/${PID}/cmdline")"

    printf 'Command line: %s\n\n' "${processCommand%% }"
}

processEnvironment() {
    local processVariables environmentVariables

    processVariables="$(tr '\0' '\n' 2>&- < "/proc/${PID}/environ")"

    environmentVariables=0

    while read -r environmentVariable; do
        [[ -z "${environmentVariable}" ]] && {

            continue
        }

        ((environmentVariables++))
    done <<< "${processVariables}"

    (( ${environmentVariables} == 0 )) && {

        printError "Can not show PID ${PID}'s environment, lacking permissions and/or variables."

        return 1
    }

    printf 'Environment variables:\n\n%s\n\n' "${processVariables}"
}

processOwnership() {

    stat --printf "Ownership of PID ${PID}:\n\nGroup: %G (GID: %g)\tOwner: %U (UID: %u)\n\n" "/proc/${PID}"
}

trap '{ printError "\nScript was interrupted."; exit 1; }' SIGINT

# Parse options.
optionCount=0

while getopts ':p:h' OPTION; do
    ((optionCount++))

    case "${OPTION}" in
        (p)
            PID="${OPTARG}"
        ;;
        (h)
            usage

            exit 0
        ;;
        (:)
            printError "-${OPTARG} option expected an argument.\n"

            usage

            exit 1
        ;;
        ('?')
            printError "Unknown option \"-${OPTARG}\".\n"

            usage

            exit 1
        ;;
    esac
done

[[ ${optionCount} -eq 0 ]] && {
    printError "No options were selected.\n"

    usage

    exit 1
}

# Validate option argument.
[[ "${PID}" =~ ^[0-9]+$ ]] || {
    printError "PID must be numeric.\n"

    usage

    exit 1
}

[[ -d "/proc/${PID}" ]] || {
    printError "PID \"${PID}\" does not exist.\n"

    usage

    exit 1
}

# Show PID information.
printf "PID ${PID} information:\n\n"

processName
processStatus
processCommand
processOwnership
processFDs
processEnvironment

trap &> /dev/null
