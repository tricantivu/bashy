# Functions
usage() {
    local scriptName="${0##*/}"

    cat << HERE
Description: Show information of a process identifier.
Usage: ${scriptName} <OPTION> <PID>

Available options:

    -p PID
        Show the information for process identifier PID.

    -h
        Show script usage.
HERE
}

printError() {
    printf "$1\n" >&2
}

processName() {
    local name=''

    while read -r name; do
        printf 'Process: %s\n' "${name}"
    done < <(cat "/proc/${PID}/comm")
}

processStatus() {
    local fileLine

    while read -r fileLine; do
        [[ "${fileLine}" == State:* ]] && {
            # Parse the status.
            prefixRemoved="${fileLine#State:}"
            tabRemoved="${prefixRemoved##$'\t'}"
            letterRemoved="${tabRemoved#[RSDZTtWXxKP]' '}"
            parenthesisRemoved="${letterRemoved//[()]/}"

            printf 'Status: %s\n' "${parenthesisRemoved^}"

            break
        }

    done < <(cat "/proc/${PID}/status")
}

processFDs() {
    local fileDescriptors

    fileDescriptors="$(find "/proc/${PID}/fdinfo" -type f -printf '%f, ' 2>&-)"

    printf 'Open file descriptors: %s\n' "${fileDescriptors%, }"
}

processCommand() {
    local processCommand

    processCommand="$(tr '\0' ' ' < "/proc/${PID}/cmdline" 2>&-)"

    printf 'Command line: %s\n' "${processCommand%% }"
}

trap '{ printError "\nScript was interrupted."; exit 1; }' SIGINT

# Parse options.
optionCount=0

while getopts ':p:h' OPTION; do
    ((optionCount++))

    case "${OPTION}" in
        (p)
            PID="${OPTARG}"
        ;;
        (h)
            { usage; exit 0; }
        ;;
        (:)
            { printError "-${OPTARG} option expected an argument.\n"; usage; exit 1; }
        ;;
        ('?')
            { printError "Unknown option \"-${OPTARG}\".\n"; usage; exit 1; }
        ;;
    esac
done

[[ ${optionCount} -eq 0 ]] && { printError "No options were selected.\n"; usage; exit 1; }

# Validate option argument.
[[ -d "/proc/${PID}" ]] || { printError "PID \"${PID}\" does not exist.\n"; usage; exit 1; }

# Show PID information.
printf "PID ${PID} information:\n\n"

processName
processStatus
processCommand
processFDs

trap &> /dev/null
